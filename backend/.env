# FastAPI settings
APP_NAME=Empathic Credit System API
APP_HOST=0.0.0.0
APP_PORT=8000

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
rabbitmq_url=amqp://guest:guest@rabbitmq:5672//

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Database
DATABASE_URL=postgresql://user:pass@db:5432/ecs

# Secret Key
SECRET_KEY=your_secret_key_here

# Basic Auth
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=test
